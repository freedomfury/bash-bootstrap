{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Packer Builder Template",
    "type": "object",
    "required": [
        "build"
    ],
    "properties": {
        "build": {
            "type": "object",
            "required": [
                "name",
                "sources",
                "provisioners"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Arbitrary name for this build block."
                },
                "sources": {
                    "type": "array",
                    "minItems": 1,
                    "description": "List of sources to build against. Each image_name must exist in images.auto.pkrvars.hcl.",
                    "items": {
                        "type": "object",
                        "required": [
                            "image_name",
                            "source_name"
                        ],
                        "additionalProperties": false,
                        "properties": {
                            "image_name": {
                                "type": "string",
                                "description": "Key from image_maps in images.auto.pkrvars.hcl (e.g. almalinux-97)."
                            },
                            "source_name": {
                                "type": "string",
                                "description": "Arbitrary unique name for this source block (e.g. alma-shell-1)."
                            }
                        }
                    }
                },
                "provisioners": {
                    "type": "array",
                    "minItems": 0,
                    "description": "Ordered list of provisioners injected between the fixed initialize and cleanup blocks.",
                    "items": {
                        "oneOf": [
                            {
                                "allOf": [
                                    {
                                        "$ref": "provisoner/shell.schema.json"
                                    },
                                    {
                                        "properties": {
                                            "name": {
                                                "type": "string",
                                                "description": "Packer meta: label for this provisioner step."
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                ]
                            },
                            {
                                "allOf": [
                                    {
                                        "$ref": "provisoner/ansible.schema.json"
                                    },
                                    {
                                        "properties": {
                                            "name": {
                                                "type": "string",
                                                "description": "Packer meta: label for this provisioner step."
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                ]
                            },
                            {
                                "allOf": [
                                    {
                                        "$ref": "provisoner/shell-local.schema.json"
                                    },
                                    {
                                        "properties": {
                                            "name": {
                                                "type": "string",
                                                "description": "Packer meta: label for this provisioner step."
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                }
            }
        }
    }
}