# exports -- Monolithic project environment variables.
# Source this file to set up the MKS environment.
# This is a static file (checked into version control), not generated by Make.

# mks::guard -- verify that all required MKS_* globals are set.
# Exported so it's available to subshells from shebang execution.
mks::guard() {
    local _var _errors=0
    for _var in MKS_ROOT MKS_TMP MKS_VENDOR MKS_BASH; do
        [[ -n "${!_var:-}" ]] || {
            printf 'FATAL: %s is not set — source exports first\n' "${_var}" >&2
            ((_errors++)) || true
        }
    done
    ((_errors == 0))
}
export -f mks::guard

if [[ "${MKS_EXPORTED:-}" == "true" ]]; then
    return 0
fi

# Compute root first to avoid shellcheck SC2155
_MKS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
declare -xr MKS_ROOT="${_MKS_ROOT}"
unset _MKS_ROOT

declare -xr MKS_TMP="${MKS_ROOT}/tmp"
declare -xr MKS_VENDOR="${MKS_ROOT}/vendor/bin"
declare -xr MKS_BASH="${MKS_VENDOR}/mks-bash"
declare -xr MKS_EXPORTED=true

if [[ -d "${MKS_VENDOR}/dev" ]]; then
    export PATH="${MKS_VENDOR}:${MKS_VENDOR}/dev:${PATH}"
else
    export PATH="${MKS_VENDOR}:${PATH}"
fi
