#!/usr/bin/env mks-bash
# .agent/skills/compose/bin/stop -- stop and destroy a Compose session

set -euo pipefail
shopt -s inherit_errexit
IFS=$'\n\t'

[[ -n "${MKS_ROOT:-}" ]] || {
  lib::std::logger -l error -m "MKS_ROOT is not set — run via make or source exports first"
  exit 3
}

# shellcheck source=lib/std/logger.sh
source "${MKS_ROOT}/lib/std/logger.sh"

# Usage:
#   stop [options]
#
# Stops and removes a Podman Compose session. By default, named volumes
# are preserved. Pass --volumes to remove them as well.
#
# Options:
#   -n, --name <project>   Project name (required)
#   -v, --volumes          Remove named volumes
#   -h, --help             Show this help and exit
#
# Returns:
#   0  success
#   1  usage error
#   3  environment error (MKS_ROOT not set, podman-compose not found)
# --

readonly _SELF="${0##*/}"

# -- Trap handlers
_cleanup() {
  local exit_code=$?
  # Clean up temp files or release locks here
  exit "${exit_code}"
}

_on_error() {
  lib::std::logger -l error -m "${BASH_SOURCE[0]} failed at line $1 (exit $?)"
}

trap '_cleanup' EXIT
trap '_on_error "${LINENO}"' ERR

# usage -- print usage message, then exit 1
usage() {
  cat <<'EOF'
Usage: stop [options]

Stops and removes a Podman Compose session. By default, named volumes
are preserved. Pass --volumes to remove them as well.

Options:
  -n, --name <project>   Project name (required)
  -v, --volumes          Remove named volumes
  -h, --help             Show this help and exit

Returns:
  0  success
  1  usage error
  3  environment error (MKS_ROOT not set, podman-compose not found)
EOF
  exit 1
}

# _require_podman -- fail fast if podman is not on PATH
# INTERNAL: positional-only, called once
_require_podman() {
  command -v podman > /dev/null 2>&1 || {
    lib::std::logger -l error -m "podman not found on PATH"
    exit 3
  }
}

main() {
  _require_podman

  local project_name=""
  local remove_volumes=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n | --name)
        if [[ -z "${2:-}" ]] || [[ "${2}" == -* ]]; then
          lib::std::logger -l error -m "--name requires a project name argument"
          return 1
        fi
        project_name="$2"
        shift 2
        ;;
      -v | --volumes)
        remove_volumes=1
        shift
        ;;
      -h | --help)
        usage
        ;;
      --)
        shift
        break
        ;;
      -*)
        lib::std::logger -l error -m "unknown option: $1"
        return 1
        ;;
      *)
        lib::std::logger -l error -m "unexpected argument: $1"
        return 1
        ;;
    esac
  done

  # Validate project name was provided
  if [[ -z "${project_name}" ]]; then
    lib::std::logger -l error -m "--name is required"
    return 1
  fi

  # Find and stop containers for this project
  local filter="label=com.docker.compose.project=${project_name}"
  local containers
  containers="$(podman ps --filter "${filter}" --format '{{.Names}}' 2>/dev/null)" || true

  if [[ -z "${containers}" ]]; then
    lib::std::logger -l error -m "no running containers found for session \"${project_name}\""
    return 1
  fi

  lib::std::logger -l info -m "stopping session \"${project_name}\"..."

  # Stop and remove each container
  while IFS= read -r container; do
    [[ -n "${container}" ]] || continue
    podman stop "${container}" >/dev/null 2>&1 || true
    podman rm "${container}" >/dev/null 2>&1 || true
  done <<< "${containers}"

  # Remove volumes if requested
  if (( remove_volumes )); then
    local volumes
    volumes="$(podman volume ls --filter "label=com.docker.compose.project=${project_name}" --format '{{.Name}}' 2>/dev/null)" || true
    while IFS= read -r volume; do
      [[ -n "${volume}" ]] || continue
      podman volume rm "${volume}" >/dev/null 2>&1 || true
    done <<< "${volumes}"
    lib::std::logger -l info -m "session \"${project_name}\" stopped (volumes removed)"
  else
    lib::std::logger -l info -m "session \"${project_name}\" stopped (volumes preserved)"
    printf '  Run with --volumes to remove named volumes\n' >&2
  fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
