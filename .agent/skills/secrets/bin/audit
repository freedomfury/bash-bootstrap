#!/usr/bin/env mks-bash
# .agent/skills/secrets/bin/audit -- Verify secrets recipients
#
# Usage:
#   audit [--verbose]
#
# Options:
#   -v, --verbose    Enable verbose output
#   -h, --help       Show this help and exit
# -----------------------------------------------------------------------------

set -euo pipefail
shopt -s inherit_errexit
IFS=$'\n\t'

# -- MKS_ROOT must be set (run via make or source exports first)
[[ -n "${MKS_ROOT:-}" ]] || {
  lib::std::logger -l error -m "MKS_ROOT is not set — run via make or source exports first"
  exit 3
}

# -- Source libraries
# shellcheck source=lib/std/logger.sh
source "${MKS_ROOT}/lib/std/logger.sh"

readonly _SELF="${0##*/}"
readonly _INSPECT="${MKS_VENDOR}/dev/age-inspect"

# -- Trap handlers
_cleanup() {
  local exit_code=$?
  # Clean up temp files or release locks here
  exit "${exit_code}"
}

_on_error() {
  lib::std::logger -l error -m "${BASH_SOURCE[0]} failed at line $1 (exit $?)"
}

trap '_cleanup' EXIT
trap '_on_error "${LINENO}"' ERR

# -- usage: print usage block and exit 1
usage() {
  sed -n '2,/^[^#]/p' "${BASH_SOURCE[0]}" | sed -n 's/^# \{0,1\}//p'
  exit 1
}

# -- main: entry point
main() {
  local verbose=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -v | --verbose)  verbose=1;   shift 1 ;;
      -h | --help)     usage ;;
      --)              shift; break ;;
      --* | -*)
        lib::std::logger -l error -m "unknown option: $1"
        usage
        ;;
      *)
        break
        ;;
    esac
  done

  [[ -x "${_INSPECT}" ]] || {
    lib::std::logger -l error -m "age-inspect tool not found at ${_INSPECT}"
    exit 3
  }

  lib::std::logger -l info -m "--- Secrets Audit ---"
  local count=0

  # Find all encrypted secrets in the project
  while IFS= read -r -d '' file; do
    lib::std::logger -l info -m "File: ${file}"
    "${_INSPECT}" "${file}"
    (( count++ )) || true
  done < <(find "${MKS_ROOT}" -name "*.env.sec.age" -print0)

  if (( count == 0 )); then
    lib::std::logger -l info -m "No encrypted secrets found matching *.env.sec.age"
  else
    lib::std::logger -l info -m "Audit complete: ${count} file(s) inspected."
  fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
