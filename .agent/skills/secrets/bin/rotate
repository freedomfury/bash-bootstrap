#!/usr/bin/env mks-bash
# .agent/skills/secrets/bin/rotate -- Rotate secrets with the current identity
#
# Usage:
#   rotate [--verbose]
#
# Options:
#   -v, --verbose    Enable verbose output
#   -h, --help       Show this help and exit
# -----------------------------------------------------------------------------

set -euo pipefail
shopt -s inherit_errexit
IFS=$'\n\t'

# -- MKS_ROOT must be set (run via make or source exports first)
[[ -n "${MKS_ROOT:-}" ]] || {
  lib::std::logger -l error -m "MKS_ROOT is not set — run via make or source exports first"
  exit 3
}

# -- Source libraries
# shellcheck source=lib/std/logger.sh
source "${MKS_ROOT}/lib/std/logger.sh"

readonly _SELF="${0##*/}"
readonly _PUBKEY="${MKS_TMP}/age/id_rsa.pub"
readonly _PKEY="${MKS_AGE_PKEY:-${MKS_TMP}/age/id_rsa}"

# -- Trap handlers
_cleanup() {
  local exit_code=$?
  # Clean up temp files or release locks here
  rm -f "${MKS_TMP}/rotate/*.new" 2>/dev/null || true
  exit "${exit_code}"
}

_on_error() {
  lib::std::logger -l error -m "${BASH_SOURCE[0]} failed at line $1 (exit $?)"
}

trap '_cleanup' EXIT
trap '_on_error "${LINENO}"' ERR

# -- usage: print usage block and exit 1
usage() {
  sed -n '2,/^[^#]/p' "${BASH_SOURCE[0]}" | sed -n 's/^# \{0,1\}//p'
  exit 1
}

# -- main: entry point
main() {
  local verbose=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -v | --verbose)  verbose=1;   shift 1 ;;
      -h | --help)     usage ;;
      --)              shift; break ;;
      --* | -*)
        lib::std::logger -l error -m "unknown option: $1"
        usage
        ;;
      *)
        break
        ;;
    esac
  done

  [[ -f "${_PKEY}"   ]] || { lib::std::logger -l error -m "identity not found: ${_PKEY}"; exit 3; }
  [[ -f "${_PUBKEY}" ]] || { lib::std::logger -l error -m "pubkey not found: ${_PUBKEY}"; exit 3; }

  lib::std::logger -l info -m "--- Secrets Rotation ---"
  lib::std::logger -l info -m "Using identity: ${_PKEY}"
  lib::std::logger -l info -m "Using recipient: $(cat "${_PUBKEY}")"

  local count=0
  while IFS= read -r -d '' file; do
    lib::std::logger -l info -m "Rotating: ${file}..."

    # Decrypt to memory, then re-encrypt with current pubkey
    local plaintext
    plaintext="${ age --decrypt --identity "${_PKEY}" "${file}"; }"

    printf '%s' "${plaintext}" | age --encrypt --armor \
      --recipient "$(cat "${_PUBKEY}")" \
      --output "${file}.new"

    mv "${file}.new" "${file}"
    lib::std::logger -l info -m "DONE"
    (( count++ )) || true
  done < <(find "${MKS_ROOT}" -name "*.env.sec.age" -print0)

  lib::std::logger -l info -m "Rotation complete: ${count} file(s) updated."
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
