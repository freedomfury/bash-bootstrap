#!/usr/bin/env mks-bash

set -euo pipefail
shopt -s inherit_errexit
IFS=$'\n\t'

[[ -n "${MKS_ROOT:-}" ]] || { echo 'Fatal: MKS_ROOT is not set!' >&2; exit 3; }

# bin/facts-global-os -- gather OS facts and write a sourceable env file
#
# Usage:
#   facts-global [--prefix <name>] [--output <file>] [--verbose]
#
# Options:
#   -p, --prefix  <name>   Variable name prefix (default: MKS_OS_FACTS)
#   -o, --output  <file>   Output file (default: ${MKS_ROOT}/tmp/cache/facts/<script>.env)
#   -v, --verbose           Enable verbose output
#   -h, --help              Show this help and exit
#
# Returns:
#   0  success
#   1  usage error
#   3  environment error (MKS_ROOT not set, Bash version)
#   4  I/O error (/etc/os-release not found)
# ---------------------------------------------------------------------------


# -- Source libraries
# shellcheck source=lib/std/logger.sh
source "${MKS_ROOT}/lib/std/logger.sh"


readonly _SELF="${0##*/}"
readonly _FACTS_CACHE_DIR="${MKS_ROOT}/tmp/cache/facts"
readonly _DEFAULT_OUTPUT="${_FACTS_CACHE_DIR}/${_SELF}.env"

# -- Trap handlers
_cleanup() {
  local exit_code=$?
  exit "${exit_code}"
}

_on_error() {
  printf 'ERROR: %s failed at line %d (exit %d)\n' \
    "${BASH_SOURCE[0]}" "$1" "$?" >&2
}

trap '_cleanup'              EXIT
trap '_on_error "${LINENO}"' ERR

# -- usage: print usage block and exit 1
usage() {
  sed -n '2,/^[^#]/p' "${BASH_SOURCE[0]}" | sed -n 's/^# \{0,1\}//p'
  exit 1
}

# -- main: gather OS facts and write to env file
main() {
  local -A opts=(
    [prefix]="MKS_OS_FACTS"
    [output]="${_DEFAULT_OUTPUT}"
    [verbose]=0
  )

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p | --prefix)   opts[prefix]="$2";  shift 2 ;;
      -o | --output)   opts[output]="$2";  shift 2 ;;
      -v | --verbose)  opts[verbose]=1;    shift 1 ;;
      -h | --help)     usage ;;
      --)              shift; break ;;
      --* | -*)
        printf '%s: unknown option: %s\n' "${_SELF}" "$1" >&2
        usage
        ;;
      *)
        printf '%s: unexpected argument: %s\n' "${_SELF}" "$1" >&2
        usage
        ;;
    esac
  done

  (( opts[verbose] )) && printf 'opts: %s\n' "${opts[*]@K}" >&2

  # -- Verify /etc/os-release is present
  [[ -f /etc/os-release ]] || {
    printf '%s: /etc/os-release not found\n' "${_SELF}" >&2
    exit 4
  }

  # -- Source /etc/os-release into current scope
  # shellcheck source=/dev/null
  source /etc/os-release

  # -- Gather system facts
  local arch hostname_short hostname_fqdn ipv4 \
        kernel_release cpu_count mem_total_kb \
        nic_default gateway_ipv4 virt_type timezone
  arch="${ uname -m; }"
  hostname_short="${ hostname -s; }"
  hostname_fqdn="${ hostname -f; }"
  ipv4="${ hostname -I | awk '{print $1}'; }"
  kernel_release="${ uname -r; }"
  cpu_count="${ nproc; }"
  mem_total_kb="${ awk '/MemTotal/{print $2}' /proc/meminfo; }"
  nic_default="${ ip route show default | awk '{print $5; exit}'; }"
  gateway_ipv4="${ ip route show default | awk '{print $3; exit}'; }"
  # systemd-detect-virt exits 1 on bare metal ("none") — suppress exit code
  virt_type="${ systemd-detect-virt || true; }"
  timezone="${ timedatectl show --property=Timezone --value; }"
  local timezone_abbr
  printf -v timezone_abbr '%(%Z)T' "${EPOCHSECONDS}"

  # -- Prepare output directory and atomic temp file
  local out_dir="${opts[output]%/*}"
  mkdir -p "${out_dir}"

  local tmpfile
  tmpfile="${ mktemp "${out_dir}/${_SELF}.XXXXXX"; }"
  trap 'rm -f "${tmpfile}"' RETURN

  # -- Write timestamp header (no subprocess — printf builtin %()T)
  local ts generated_epoch=${EPOCHSECONDS}
  printf -v ts '%(%Y-%m-%dT%H:%M:%S)T' "${generated_epoch}"

  {
    printf '# generated by: %s\n' "${_SELF}"
    printf '# generated at: %s\n' "${ts}"
    printf '#\n'
    printf '%s_PRETTY_NAME=%#Q\n'      "${opts[prefix]}" "${PRETTY_NAME:-}"
    printf '%s_NAME=%#Q\n'             "${opts[prefix]}" "${NAME:-}"
    printf '%s_VERSION_ID=%#Q\n'       "${opts[prefix]}" "${VERSION_ID:-}"
    printf '%s_VERSION=%#Q\n'          "${opts[prefix]}" "${VERSION:-}"
    printf '%s_VERSION_CODENAME=%#Q\n' "${opts[prefix]}" "${VERSION_CODENAME:-}"
    printf '%s_ID=%#Q\n'               "${opts[prefix]}" "${ID:-}"
    printf '%s_ID_LIKE=%#Q\n'          "${opts[prefix]}" "${ID_LIKE:-}"
    printf '%s_ARCH=%#Q\n'             "${opts[prefix]}" "${arch}"
    printf '%s_HOSTNAME_SHORT=%#Q\n'   "${opts[prefix]}" "${hostname_short}"
    printf '%s_HOSTNAME_FQDN=%#Q\n'    "${opts[prefix]}" "${hostname_fqdn}"
    printf '%s_IPV4=%#Q\n'             "${opts[prefix]}" "${ipv4}"
    printf '%s_KERNEL_RELEASE=%#Q\n'   "${opts[prefix]}" "${kernel_release}"
    printf '%s_CPU_COUNT=%#Q\n'        "${opts[prefix]}" "${cpu_count}"
    printf '%s_MEM_TOTAL_KB=%#Q\n'     "${opts[prefix]}" "${mem_total_kb}"
    printf '%s_NIC_DEFAULT=%#Q\n'      "${opts[prefix]}" "${nic_default}"
    printf '%s_GATEWAY_IPV4=%#Q\n'     "${opts[prefix]}" "${gateway_ipv4}"
    printf '%s_VIRT_TYPE=%#Q\n'        "${opts[prefix]}" "${virt_type}"
    printf '%s_TIMEZONE=%#Q\n'         "${opts[prefix]}" "${timezone}"
    printf '%s_TIMEZONE_ABBR=%#Q\n'    "${opts[prefix]}" "${timezone_abbr}"
    printf '%s_TIME=%#Q\n'             "${opts[prefix]}" "${ts}"
    printf '%s_EPOCH=%#Q\n'            "${opts[prefix]}" "${generated_epoch}"
  } > "${tmpfile}"

  # -- Atomic move to final location
  mv "${tmpfile}" "${opts[output]}"

  lib::std::logger --level info \
    --message "facts written: ${opts[output]}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
