#!/usr/bin/env mks-bash

set -euo pipefail
shopt -s inherit_errexit
IFS=$'\n\t'

[[ -n "${MKS_ROOT:-}" ]] || { echo 'Fatal: MKS_ROOT is not set!' >&2; exit 3; }

# bin/facts-cloud-init -- parse cloud-init instance data and write a sourceable env file
#
# Usage:
#   facts-cloud-init --input <file> [--prefix <name>] [--output <file>] [--filter <keys>] [--verbose]
#
# Options:
#   -i, --input   <file>   cloud-init instance-data JSON file (required)
#   -p, --prefix  <name>   Variable name prefix (default: MKS_CI_FACTS)
#   -o, --output  <file>   Output file (default: ${MKS_ROOT}/tmp/cache/facts/<script>.env)
#   -f, --filter  <keys>   Comma-separated list of top-level keys to include (e.g. 'v1,sys_info')
#   -v, --verbose          Enable verbose output
#   -h, --help             Show this help and exit
#
# Returns:
#   0  success
#   1  usage error
#   3  environment error (MKS_ROOT not set, Bash version)
#   4  I/O error (input file not found)
# ---------------------------------------------------------------------------


# -- Source libraries
# shellcheck source=lib/std/logger.sh
source "${MKS_ROOT}/lib/std/logger.sh"


readonly _SELF="${0##*/}"
readonly _FACTS_CACHE_DIR="${MKS_ROOT}/tmp/cache/facts"
readonly _DEFAULT_OUTPUT="${_FACTS_CACHE_DIR}/${_SELF}.env"

# -- Trap handlers
_cleanup() {
  local exit_code=$?
  exit "${exit_code}"
}

_on_error() {
  printf 'ERROR: %s failed at line %d (exit %d)\n' \
    "${BASH_SOURCE[0]}" "$1" "$?" >&2
}

trap '_cleanup'              EXIT
trap '_on_error "${LINENO}"' ERR

# -- usage: print usage block and exit 1
usage() {
  sed -n '2,/^[^#]/p' "${BASH_SOURCE[0]}" | sed -n 's/^# \{0,1\}//p'
  exit 1
}

# -- main: parse cloud-init instance data and write to env file
main() {
  local -A opts=(
    [prefix]="MKS_CI_FACTS"
    [output]="${_DEFAULT_OUTPUT}"
    [input]=""
    [filter]=""
    [verbose]=0
  )

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p | --prefix)   opts[prefix]="$2";  shift 2 ;;
      -o | --output)   opts[output]="$2";  shift 2 ;;
      -i | --input)    opts[input]="$2";   shift 2 ;;
      -f | --filter)   opts[filter]="$2";  shift 2 ;;
      -v | --verbose)  opts[verbose]=1;    shift 1 ;;
      -h | --help)     usage ;;
      --)              shift; break ;;
      --* | -*)
        printf '%s: unknown option: %s\n' "${_SELF}" "$1" >&2
        usage
        ;;
      *)
        printf '%s: unexpected argument: %s\n' "${_SELF}" "$1" >&2
        usage
        ;;
    esac
  done

  (( opts[verbose] )) && printf 'opts: %s\n' "${opts[*]@K}" >&2

  # -- Require --input
  [[ -n "${opts[input]}" ]] || {
    printf '%s: --input is required\n' "${_SELF}" >&2
    exit 1
  }

  # -- Read instance data JSON from file
  [[ -f "${opts[input]}" ]] || {
    printf '%s: input file not found: %s\n' "${_SELF}" "${opts[input]}" >&2
    exit 4
  }

  # -- Prepare output directory and atomic temp file
  local out_dir="${opts[output]%/*}"
  mkdir -p "${out_dir}"

  local tmpfile
  tmpfile="${ mktemp "${out_dir}/${_SELF}.XXXXXX"; }"
  trap 'rm -f "${tmpfile}"' RETURN

  # -- Write timestamp header (no subprocess — printf builtin %()T)
  local ts generated_epoch=${EPOCHSECONDS}
  printf -v ts '%(%Y-%m-%dT%H:%M:%S)T' "${generated_epoch}"

  {
    printf '# generated by: %s\n' "${_SELF}"
    printf '# generated at: %s\n' "${ts}"
    printf '# source with:  source "%s"\n' "${opts[output]#"${MKS_ROOT}/"}"
    printf '#\n'
    printf 'declare -A %s\n' "${opts[prefix]}"
    jq -r --arg prefix "${opts[prefix]}" --arg filter "${opts[filter]}" \
        '[paths(scalars) as $path |
         select($filter == "" or ($filter | split(",") | index($path[0]) != null)) |
         {
           key:   $path | join("."),
           value: getpath($path) | tostring
         }] | .[] | "\($prefix)[\"\(.key)\"]=\(@sh "\(.value)")"' \
      "${opts[input]}"
    printf '%s_EPOCH=%s\n' "${opts[prefix]}" "${generated_epoch}"
  } > "${tmpfile}"

  # -- Atomic move to final location
  mv "${tmpfile}" "${opts[output]}"

  lib::std::logger --level info \
    --message "facts written: ${opts[output]}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
